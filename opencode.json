{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "description": "Manages the spec analysis pipeline. Classifies complexity, delegates to subagents, controls interview checkpoints. Never reads files or runs tools directly.",
      "prompt": "{file:.opencode/agents/orchestrator.md}",
      "steps": 40,
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": { "*": "deny" },
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "apply_patch": "deny",
        "alum_rag_*": "deny",
        "exa_search_*": "deny",
        "web-reader_*": "deny",
        "zai-mcp-server_*": "deny",
        "zread_*": "deny",
        "web-search-prime_*": "deny"
      }
    },
    "analyst": {
      "mode": "subagent",
      "hidden": true,
      "description": "Deep analysis of technical specifications including ML/DS/CV projects. Extracts requirements, tasks, risks, datasets, models, experiments. Builds graph. Has web search for model research.",
      "prompt": "{file:.opencode/agents/analyst.md}",
      "steps": 60,
      "temperature": 0.15,
      "permission": {
        "alum_rag_*": "deny",
        "zai-mcp-server_*": "deny"
      }
    },
    "interviewer": {
      "mode": "subagent",
      "hidden": true,
      "description": "Iteratively asks user targeted questions to resolve uncertainties. Updates graph with answers. Read-only except graph updates.",
      "prompt": "{file:.opencode/agents/interviewer.md}",
      "steps": 25,
      "temperature": 0.3,
      "permission": {
        "write": "deny",
        "bash": { "*": "deny" },
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "apply_patch": "deny",
        "alum_rag_*": "deny",
        "exa_search_*": "deny",
        "web-reader_*": "deny",
        "zai-mcp-server_*": "deny",
        "zread_*": "deny",
        "web-search-prime_*": "deny"
      }
    },
    "planner": {
      "mode": "subagent",
      "hidden": true,
      "description": "Creates execution plans with timelines, resource estimates, equipment selection, and GPU compute planning. Uses web search for hardware/software/cloud research.",
      "prompt": "{file:.opencode/agents/planner.md}",
      "steps": 50,
      "temperature": 0.15,
      "permission": {
        "alum_rag_*": "deny",
        "zai-mcp-server_*": "deny"
      }
    },
    "synthesizer": {
      "mode": "subagent",
      "hidden": true,
      "description": "Synthesizes improved specification from analysis data, interview results, and execution plan. Writes final output documents.",
      "prompt": "{file:.opencode/agents/synthesizer.md}",
      "steps": 40,
      "temperature": 0.1,
      "permission": {
        "bash": { "*": "deny" },
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "apply_patch": "deny",
        "alum_rag_*": "deny",
        "exa_search_*": "deny",
        "web-reader_*": "deny",
        "zai-mcp-server_*": "deny",
        "zread_*": "deny",
        "web-search-prime_*": "deny"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "hidden": true,
      "description": "Reviews spec analysis for completeness, consistency, and achievability. Read-only. Runs validation tools.",
      "prompt": "{file:.opencode/agents/reviewer.md}",
      "steps": 30,
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "apply_patch": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "alum_rag_*": "deny",
        "exa_search_*": "deny",
        "web-reader_*": "deny",
        "zai-mcp-server_*": "deny",
        "zread_*": "deny",
        "web-search-prime_*": "deny"
      }
    }
  }
}
